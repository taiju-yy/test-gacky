{
  "type": "flex",
  "altText": "COMMENT",

  "contents": {
    "type": "bubble",
    "hero": {
      "type": "image",
      "url": "https://res-gacky-bot.s3.ap-northeast-1.amazonaws.com/fm_image_aozora.png",
      "size": "full",
      "aspectRatio": "20:13",
      "aspectMode": "cover",
      "action": {
        "type": "uri",
        "uri": "LINE_LINK"
      }
    },
    "body": {
      "type": "box",
      "layout": "vertical",
      "contents": [
        {
          "type": "text",
          "text": "STORE_NAME",
          "weight": "bold",
          "size": "xl"
        },
        {
          "type": "box",
          "layout": "vertical",
          "margin": "lg",
          "spacing": "sm",
          "contents": [
            {
              "type": "box",
              "layout": "baseline",
              "spacing": "sm",
              "contents": [
                {
                  "type": "icon",
                  "url": "https://res-gacky-bot.s3.ap-northeast-1.amazonaws.com/fm_image_location_bl.png",
                  "size": "15px",
                  "offsetTop": "2px"
                },
                {
                  "type": "text",
                  "text": "STORE_ADDRESS",
                  "wrap": true,
                  "color": "#666666",
                  "size": "sm",
                  "flex": 5,
                  "action": {
                    "type": "uri",
                    "uri": "STORE_ADDRESS_LINK"
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    "footer": {
      "type": "box",
      "layout": "vertical",
      "spacing": "sm",
      "contents": [
        {
          "type": "button",
